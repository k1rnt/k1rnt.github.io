---
import '../styles/global.css';
import { Icon } from 'astro-icon/components';
const title = "k1rnt - Security Engineer";
const description = "Security Engineer / Software Engineer / CTF Player";
const ogImage = "/icon.png";
const credits = [
  {
    title: "CVE-2026-33810 Case-Sensitive DNS Name Constraint Bypass in Go crypto/x509",
    links: [
      "https://www.cve.org/CVERecord?id=CVE-2026-33810",
      "https://pkg.go.dev/vuln/GO-2026-4866",
      "https://groups.google.com/g/golang-announce/c/0uYbvbPZRWU",
      "https://flatt.tech/cve/2026-33810",
    ],
  },
  {
    title: "x/net/quic: remote panic via short dstConnID in retry token validation",
    links: [
      "https://github.com/golang/go/issues/78292",
    ],
  },
  {
    title: "Unauthenticated Path Traversal -> Arbitrary File Read (Repository & Host OS)",
    links: [
      "https://bughunters.google.com/reports/vrp/ZqsiiwS5f/report",
    ],
  },
  {
    title: "Blink CSSOM: renderer stack overflow via deeply nested CSSMathSum",
    links: [
      "https://issues.chromium.org/u/2/issues/517550063",
    ],
  },
  {
    title: "Hack The Box Omniscient Rank",
    links: [
      "https://labs.hackthebox.com/achievement/badge/1415870/219",
    ],
  },
];
const media = [
  {
    title: "実務で担当するまでに独学した、攻撃者視点のセキュリティ",
    links: [
      "https://note.com/flatt_security/n/nb91c25832e7c?magazine_key=m13febbcd01c3",
    ],
  },
  {
    title: "3名のOSWE合格記と資格取得支援について - セキュリティエンジニア鼎談",
    links: [
      "https://note.com/flatt_security/n/n7f452420249c?magazine_key=m13febbcd01c3",
    ],
  },
  {
    title: "Hello, Flattmate!｜セキュリティエンジニア てぃー",
    links: [
      "https://note.com/flatt_security/n/nf0b85a5ea355",
    ],
  },
  {
    title: "攻めと守りで理解するPHPアプリケーションのセキュリティ：生成AI時代のXSSとその対策",
    links: [
      "https://developers.gmo.jp/technology/66864/",
      "https://speakerdeck.com/flatt_security/gong-me-to-shou-ri-deli-jie-suru-php-apurikesiyon",
    ],
  },
];
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;" />
    <link rel="icon" href="/favicon.ico" />
    <script is:inline>
      const theme = localStorage.getItem("theme");
      if (theme === "dark" || (!theme && matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="bg-slate-100 dark:bg-slate-900 font-sans min-h-screen bg-no-repeat bg-cover bg-center transition-colors duration-300" style="background-image: url('/background.webp')">
    <div class="backdrop-blur-sm backdrop-saturate-150 bg-white/70 dark:bg-slate-900/80 min-h-screen py-6 px-4 sm:py-16 sm:px-6 transition-colors duration-300">
      <main class="max-w-3xl mx-auto bg-white/90 dark:bg-slate-800/90 rounded-2xl shadow-xl p-6 sm:p-10 transition-colors duration-300 relative">
        <div class="absolute top-4 right-4">
          <button id="theme-toggle" class="p-2 rounded-lg bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors" aria-label="Toggle dark mode">
            <svg id="icon-sun" class="w-5 h-5 text-yellow-500 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
            </svg>
            <svg id="icon-moon" class="w-5 h-5 text-slate-700 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
            </svg>
          </button>
        </div>

        <img src="/icon.png" alt="Icon" class="w-24 h-24 rounded-full mx-auto mb-6 border dark:border-slate-600 shadow-md" loading="lazy" />
        <h1 class="text-5xl font-extrabold mb-4 text-center dark:text-white">k1rnt</h1>
        <p class="mb-8 text-lg text-gray-700 dark:text-gray-300 text-center text-pretty">Security Engineer & Software Developer passionate about offensive security and CTFs.</p>

        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-2 border-b dark:border-slate-600 pb-1 dark:text-white">Jobs</h2>
          <ul class="list-disc list-inside space-y-1 dark:text-gray-300">
            <li>2024/11 ~ current: Security Engineer at <a href="https://flatt.tech" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">GMO Flatt Security</a></li>
            <li>2023/09 ~ 2024/10: Security Engineer at <a href="https://3-shake.com/" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">3-shake</a></li>
            <li>2022/02 ~ 2023/08: SWE at <a href="https://stafes.co.jp/" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">STAR FESTIVAL</a></li>
            <li>2020/05 ~ 2022/02: SWE at full-time employee</li>
            <li>2020/01 ~ 2020/04: SWE at part-time job</li>
            <li>2015/11 ~ 2016/12: SWE at part-time job</li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-2 border-b dark:border-slate-600 pb-1 dark:text-white">Skills</h2>
          <div>
              <ul class="list-disc list-inside space-y-1 dark:text-gray-300">
                <li>Software Engineering</li>
                <li>White-box Security Testing</li>
                <li>Penetration Testing</li>
                <li>Red Team</li>
                <li>Security Research</li>
              </ul>
          </div>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-2 border-b dark:border-slate-600 pb-1 dark:text-white">Certifications</h2>
          <ul class="list-disc list-inside space-y-1 dark:text-gray-300">
            <li>Certified Red Team Professional (CRTP) - June 2026</li>
            <li>OSWE (OffSec Web Expert) - October 2025</li>
            <li>Driver's License - December 2019</li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-2 border-b dark:border-slate-600 pb-1 dark:text-white">Credits</h2>
          <ul class="space-y-4">
            {credits.map((item) => (
              <li>
                <p class="font-medium text-gray-900 dark:text-gray-100">{item.title}</p>
                <ul class="list-disc list-inside mt-2 space-y-1 text-sm break-all">
                  {item.links.map((link) => (
                    <li class="dark:text-gray-400">
                      <a href={link} class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">
                        {link}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ))}
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-2 border-b dark:border-slate-600 pb-1 dark:text-white">Media</h2>
          <ul class="space-y-4">
            {media.map((item) => (
              <li>
                <p class="font-medium text-gray-900 dark:text-gray-100">{item.title}</p>
                <ul class="list-disc list-inside mt-2 space-y-1 text-sm break-all">
                  {item.links.map((link) => (
                    <li class="dark:text-gray-400">
                      <a href={link} class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">
                        {link}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ))}
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-2 border-b dark:border-slate-600 pb-1 dark:text-white">Links</h2>
          <ul class="space-y-2">
            <li class="flex items-center gap-2">
              <Icon name="mdi:github" class="w-5 h-5 text-gray-700 dark:text-gray-300" />
              <a href="https://github.com/k1rnt" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">Github</a>
            </li>
            <li class="flex items-center gap-2">
              <Icon name="mdi:twitter" class="w-5 h-5 text-gray-700 dark:text-gray-300" />
              <a href="https://x.com/k1rnt" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">X (Twitter)</a>
            </li>
            <li class="flex items-center gap-2">
              <Icon name="mdi:book-open-variant" class="w-5 h-5 text-gray-700 dark:text-gray-300" />
              <a href="https://blog.k1rnt.me" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">Blog</a>
            </li>
            <li class="flex items-center gap-2">
              <Icon name="mdi:book-open-variant" class="w-5 h-5 text-gray-700 dark:text-gray-300" />
              <a href="https://scrapbox.io/k1rnt-scrap/" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener noreferrer">Little knowledge</a>
            </li>
          </ul>
        </section>
      </main>
    </div>

    <script is:inline>
      document.getElementById("theme-toggle").addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    </script>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "efd741e2e1474daead4d93a5ac4c7f5e"}'></script>
  </body>
</html>
